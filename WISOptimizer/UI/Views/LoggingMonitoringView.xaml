<UserControl x:Class="WISOptimizer.UI.Views.LoggingMonitoringView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="{StaticResource TextBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="Logging &amp; Monitoring" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Track system events, crashes, shutdowns and device disconnects." Foreground="{StaticResource SecondaryTextBrush}" FontSize="14"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                <GroupBox Header="Tracking Options">
                    <StackPanel>
                        <DockPanel Margin="0,5">
                            <TextBlock Text="Enable Event Viewer monitoring" VerticalAlignment="Center"/>
                            <CheckBox x:Name="chkEventViewer" Style="{StaticResource ToggleSwitch}" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Separator Background="{StaticResource BorderBrush}" Margin="0,8"/>
                        <DockPanel Margin="0,5">
                            <TextBlock Text="Enable Shutdown tracking" VerticalAlignment="Center"/>
                            <CheckBox x:Name="chkShutdownTracking" Style="{StaticResource ToggleSwitch}" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Separator Background="{StaticResource BorderBrush}" Margin="0,8"/>
                        <DockPanel Margin="0,5">
                            <TextBlock Text="Enable Crash tracking" VerticalAlignment="Center"/>
                            <CheckBox x:Name="chkCrashTracking" Style="{StaticResource ToggleSwitch}" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Separator Background="{StaticResource BorderBrush}" Margin="0,8"/>
                        <DockPanel Margin="0,5">
                            <TextBlock Text="Enable Device disconnect tracking" VerticalAlignment="Center"/>
                            <CheckBox x:Name="chkDeviceDisconnect" Style="{StaticResource ToggleSwitch}" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Live Log Viewer">
                    <StackPanel>
                        <Border Background="#1A1A1A" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10" CornerRadius="4" Margin="0,0,0,10">
                            <TextBox x:Name="txtLiveLogs" Height="120" Background="Transparent" Foreground="#00FF88" FontFamily="Consolas" IsReadOnly="True" BorderThickness="0" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                        </Border>
                        <Button Content="Export Logs" Style="{StaticResource ModernButton}" HorizontalAlignment="Left" Width="120" Click="ExportLogs_Click"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Apply Monitoring Settings" Style="{StaticResource ModernButton}" Click="Apply_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
