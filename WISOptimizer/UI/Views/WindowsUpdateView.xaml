<UserControl x:Class="WISOptimizer.UI.Views.WindowsUpdateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="{DynamicResource TextBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="Windows Update Control" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Prevent unwanted updates from interrupting WIS / CamControl operations." Foreground="{DynamicResource SecondaryTextBrush}" FontSize="14"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                <GroupBox Header="Update Services">
                    <StackPanel>
                        <DockPanel Margin="0,5">
                            <StackPanel>
                                <TextBlock Text="Disable Windows Update (wuauserv)" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblWuStatus" Text="● Checking..." FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                            <CheckBox x:Name="chkDisableWindowsUpdate" IsChecked="{Binding DisableWindowsUpdate}" Style="{StaticResource ToggleSwitch}" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,10"/>

                        <DockPanel Margin="0,5">
                            <StackPanel>
                                <TextBlock Text="Disable Delivery Optimization (DoSvc)" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblDoStatus" Text="● Checking..." FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                            <CheckBox x:Name="chkDisableDeliveryOpt" IsChecked="{Binding DisableDeliveryOpt}" Style="{StaticResource ToggleSwitch}" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,10"/>

                        <DockPanel Margin="0,5">
                            <TextBlock Text="Disable Update Orchestrator (UsoSvc)" VerticalAlignment="Center"/>
                            <CheckBox x:Name="chkDisableUpdateOrchestrator" IsChecked="{Binding DisableUpdateOrchestrator}" Style="{StaticResource ToggleSwitch}" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Apply Update Settings" Style="{StaticResource ModernButton}" Click="Apply_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
