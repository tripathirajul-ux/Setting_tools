<UserControl x:Class="WISOptimizer.UI.Views.NetworkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="{StaticResource TextBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="Network Optimization" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Optimize network adapter settings and configure static IPs." Foreground="{StaticResource SecondaryTextBrush}" FontSize="14"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                <GroupBox Header="Static IP Configuration">
                    <StackPanel>
                        <DockPanel Margin="0,5">
                            <TextBlock Text="Enable Static IP" VerticalAlignment="Center"/>
                            <CheckBox x:Name="chkStaticIp" Style="{StaticResource ToggleSwitch}" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Separator Background="{StaticResource BorderBrush}" Margin="0,10"/>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="IP Address" Grid.Row="0" VerticalAlignment="Center" Margin="0,5"/>
                            <TextBox x:Name="txtIpAddress" Grid.Row="0" Grid.Column="1" Margin="5" VerticalContentAlignment="Center"/>

                            <TextBlock Text="Gateway" Grid.Row="1" VerticalAlignment="Center" Margin="0,5"/>
                            <TextBox x:Name="txtGateway" Grid.Row="1" Grid.Column="1" Margin="5" VerticalContentAlignment="Center"/>

                            <TextBlock Text="DNS" Grid.Row="2" VerticalAlignment="Center" Margin="0,5"/>
                            <TextBox x:Name="txtDns" Grid.Row="2" Grid.Column="1" Margin="5" VerticalContentAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Adapter Optimization">
                    <StackPanel>
                        <DockPanel Margin="0,5">
                            <TextBlock Text="Disable NIC power saving" VerticalAlignment="Center"/>
                            <CheckBox x:Name="chkNicPowerSaving" Style="{StaticResource ToggleSwitch}" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Separator Background="{StaticResource BorderBrush}" Margin="0,10"/>

                        <DockPanel Margin="0,5">
                            <TextBlock Text="Disable interrupt moderation" VerticalAlignment="Center"/>
                            <CheckBox x:Name="chkInterrupt" Style="{StaticResource ToggleSwitch}" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Apply Network Settings" Style="{StaticResource ModernButton}" Click="Apply_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
