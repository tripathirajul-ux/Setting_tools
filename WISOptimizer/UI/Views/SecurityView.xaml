<UserControl x:Class="WISOptimizer.UI.Views.SecurityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="{DynamicResource TextBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="Security / Defender" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Manage Windows Defender settings and security exclusions." Foreground="{DynamicResource SecondaryTextBrush}" FontSize="14"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                <GroupBox Header="Windows Defender">
                    <StackPanel>
                        <DockPanel Margin="0,5">
                            <TextBlock Text="Disable real-time protection" VerticalAlignment="Center"/>
                            <CheckBox x:Name="chkDisableRealTime" IsChecked="{Binding DisableRealTime}" Style="{StaticResource ToggleSwitch}" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                            <TextBlock x:Name="statusDefender" Text="✔ Active" Foreground="{DynamicResource SuccessBrush}" DockPanel.Dock="Right" Margin="0,0,15,0" VerticalAlignment="Center" FontSize="12"/>
                        </DockPanel>
                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,10"/>

                        <DockPanel Margin="0,5">
                            <TextBlock Text="Windows Firewall" VerticalAlignment="Center"/>
                            <CheckBox x:Name="chkFirewall" IsChecked="True" Style="{StaticResource ToggleSwitch}" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,10"/>

                        <TextBlock Text="Exclusion Paths" FontWeight="Bold" Margin="0,5,0,5"/>
                        <TextBox x:Name="txtExclusions" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Background="#2A2A2A" Foreground="White" BorderBrush="{DynamicResource BorderBrush}" Padding="5"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="UAC &amp; Privileges">
                    <StackPanel>
                        <DockPanel Margin="0,5">
                            <TextBlock Text="UAC Level" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cboUacLevel" Width="180" DockPanel.Dock="Right">
                                <ComboBoxItem Content="Always Notify"/>
                                <ComboBoxItem Content="Notify Apps Only"/>
                                <ComboBoxItem Content="Never Notify"/>
                            </ComboBox>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Apply Security Settings" Style="{StaticResource ModernButton}" Click="Apply_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
