<UserControl x:Class="WISOptimizer.UI.Views.ConfigurationPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="{DynamicResource TextBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="Configuration Panel" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Edit and persist application settings stored in settings.json." Foreground="{DynamicResource SecondaryTextBrush}" FontSize="14"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                <GroupBox Header="Network">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="IP Address" Grid.Row="0" VerticalAlignment="Center" Margin="0,6"/>
                        <TextBox x:Name="txtIpAddress" Grid.Row="0" Grid.Column="1" Margin="5,6" VerticalContentAlignment="Center"/>
                        <TextBlock Text="Gateway" Grid.Row="1" VerticalAlignment="Center" Margin="0,6"/>
                        <TextBox x:Name="txtGateway" Grid.Row="1" Grid.Column="1" Margin="5,6" VerticalContentAlignment="Center"/>
                        <TextBlock Text="DNS" Grid.Row="2" VerticalAlignment="Center" Margin="0,6"/>
                        <TextBox x:Name="txtDns" Grid.Row="2" Grid.Column="1" Margin="5,6" VerticalContentAlignment="Center"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Camera SDK">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="SDK Port" Width="100" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtSdkPort" Width="100" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Logging">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Log Path" Width="100" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtLogPath" Width="300" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Update Configuration" Style="{StaticResource ModernButton}" Click="Apply_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
