<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ═══ COLOR PALETTE (LIGHT) ═══ -->
    <SolidColorBrush x:Key="BackgroundBrush"      Color="#F4F5F7"/>
    <SolidColorBrush x:Key="SidebarBrush"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HeaderBrush"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBrush"            Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputBrush"           Color="#EAEAEE"/>
    <SolidColorBrush x:Key="BorderBrush"          Color="#D0D3DB"/>
    <SolidColorBrush x:Key="AccentBrush"          Color="#2B6EE3"/>
    <SolidColorBrush x:Key="AccentHoverBrush"     Color="#1F57BA"/>
    <SolidColorBrush x:Key="SuccessBrush"         Color="#219E61"/>
    <SolidColorBrush x:Key="DangerBrush"          Color="#E33E3E"/>
    <SolidColorBrush x:Key="WarningBrush"         Color="#C48600"/>
    <SolidColorBrush x:Key="TextBrush"            Color="#111214"/>
    <SolidColorBrush x:Key="SecondaryTextBrush"   Color="#585D6B"/>
    <SolidColorBrush x:Key="SidebarActiveBrush"   Color="#E0E4EC"/>
    <SolidColorBrush x:Key="HoverBrush"           Color="#EBF0F8"/>
</ResourceDictionary>
